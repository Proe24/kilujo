---
import Layout from '../../layouts/Layout.astro';
import { getAlbums, getAlbumPhotos, type FlickrAlbum, type FlickrPhoto } from '../../lib/flickr';

export async function getStaticPaths() {
  const albums = await getAlbums();
  const entries = await Promise.all(
    albums.map(async (album) => ({
      params: { albumId: album.id },
      props: {
        album,
        photos: await getAlbumPhotos(album.id),
      },
    }))
  );
  return entries;
}

interface Props {
  album: FlickrAlbum;
  photos: FlickrPhoto[];
}

const { album, photos } = Astro.props;
---
<Layout title={`${album.title} — Photos`} description={album.description}>
  <div class="page">
    <div class="wrap-wide">
      <a href="/photos" class="ink-link back-link">← All albums</a>
      <header class="page-header">
        <div class="eyebrow" style="margin-bottom: 12px">
          {photos.length} photo{photos.length === 1 ? '' : 's'} · From Flickr
        </div>
        <h1><em>{album.title || 'Untitled album'}</em></h1>
        {album.description && <p class="lede">{album.description}</p>}
      </header>

      {photos.length === 0 ? (
        <div class="empty">No photos in this album.</div>
      ) : (
        <div class="photo-masonry">
          {photos.map((photo) => (
            <a
              class="photo-masonry__item"
              href={photo.largeUrl}
              data-lightbox
              data-lightbox-group={`album-${album.id}`}
              data-src={photo.largeUrl}
              data-alt={photo.title}
              aria-label={photo.title}
            >
              <img
                src={photo.thumbUrl}
                alt={photo.title}
                width={photo.width}
                height={photo.height}
                loading="lazy"
              />
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .photo-masonry {
    column-count: 3;
    column-gap: 16px;
  }
  @media (max-width: 960px) {
    .photo-masonry { column-count: 2; }
  }
  @media (max-width: 560px) {
    .photo-masonry { column-count: 1; }
  }
  .photo-masonry__item {
    display: block;
    break-inside: avoid;
    margin-bottom: 16px;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-alt);
    box-shadow: var(--shadow-soft);
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .photo-masonry__item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }
  .photo-masonry__item img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
