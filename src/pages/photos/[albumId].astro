---
import Layout from '../../layouts/Layout.astro';
import { getAlbums, getAlbumPhotos, type FlickrAlbum, type FlickrPhoto } from '../../lib/flickr';

export async function getStaticPaths() {
  const albums = await getAlbums();
  const entries = await Promise.all(
    albums.map(async (album) => ({
      params: { albumId: album.id },
      props: {
        album,
        photos: await getAlbumPhotos(album.id),
      },
    }))
  );
  return entries;
}

interface Props {
  album: FlickrAlbum;
  photos: FlickrPhoto[];
}

const { album, photos } = Astro.props;
---
<Layout title={`${album.title} — Photos`} description={album.description}>
  <div class="page">
    <div class="wrap-wide">
      <a href="/photos" class="ink-link back-link">← All albums</a>
      <header class="page-header">
        <div class="eyebrow" style="margin-bottom: 12px">
          {photos.length} photo{photos.length === 1 ? '' : 's'} · From Flickr
        </div>
        <h1><em>{album.title || 'Untitled album'}</em></h1>
        {album.description && <p class="lede">{album.description}</p>}
      </header>

      {photos.length === 0 ? (
        <div class="empty">No photos in this album.</div>
      ) : (
        <div class="card-grid">
          {photos.map((photo) => (
            <a
              class="card"
              href={photo.largeUrl}
              data-lightbox
              data-lightbox-group={`album-${album.id}`}
              data-src={photo.largeUrl}
              data-alt={photo.title}
              aria-label={photo.title}
            >
              <img class="card__image" src={photo.thumbUrl} alt={photo.title} loading="lazy" />
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>
