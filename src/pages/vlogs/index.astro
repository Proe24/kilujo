---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('vlogs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="Vlogs — Kilujo">
  <section class="intro">
    <h1>Vlogs</h1>
    <p>Little video diaries. Nothing fancy.</p>
  </section>

  {posts.length === 0 ? (
    <div class="empty">No vlogs yet. Add one in <code>src/content/vlogs/</code>.</div>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/vlogs/${post.slug}`}>{post.data.title}</a>
          <span class="post-meta">
            {formatDate(post.data.date)}
            {post.data.author ? ` · ${post.data.author}` : ''}
            {post.data.description ? ` — ${post.data.description}` : ''}
          </span>
        </li>
      ))}
    </ul>
  )}
</Layout>
