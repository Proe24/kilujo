---
import Layout from '../layouts/Layout.astro';
import DogAvatar from '../components/DogAvatars.astro';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';

const recent = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Pick a thumbnail: explicit cover, else first gallery image, else nothing.
// Mirrors the helper in src/pages/journal/index.astro.
function postThumb(post: CollectionEntry<'journal'>): string | undefined {
  if (post.data.cover) return post.data.cover;
  const g = post.data.gallery?.[0];
  if (!g) return undefined;
  return typeof g === 'string' ? g : g.src;
}

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const kindLabel: Record<string, { label: string; icon: string }> = {
  writing: { label: 'Writing', icon: '✎' },
  video:   { label: 'Video',   icon: '▶' },
  gaming:  { label: 'Gaming',  icon: '◆' },
};

const home = await getEntry('pages', 'home');
const h = home?.data ?? {};

const heroImage   = h.heroImage   ?? '/uploads/about/family.jpg';
const heroAlt     = h.heroAlt     ?? '';
const heroCaption = h.heroCaption ?? '';
const eyebrow     = h.eyebrow     ?? '';
const intro       = h.intro       ?? '';
const latelyLabel = h.latelyLabel ?? 'From the journal · Lately';
const nowMonth    = h.nowMonth
  ?? new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
const nowBody     = h.nowBody;

// Render the greeting: split on newlines, escape, then style "&" as the
// italic ampersand. set:html receives this — we control the substitution
// so no user-supplied HTML can leak through.
const escapeHtml = (s: string) =>
  s.replace(/[&<>"']/g, (c) => (
    { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!
  ));
const greetingHtml = (h.greeting ?? '')
  .split('\n')
  .map((line) => line.trimEnd())
  .filter((line) => line.length > 0)
  .map((line) => escapeHtml(line).replace(/&amp;/g, '<span class="amp">&amp;</span>'))
  .join('<br />');
---
<Layout title="kilujo · a quiet corner of the internet">
  <div class="page">
    <div class="wrap-wide" style="padding-top: 0">
      {heroImage && (
        <figure class="cover home-hero" style="margin-bottom: 36px">
          <img src={heroImage} alt={heroAlt} />
          {heroCaption && (
            <figcaption class="home-hero-caption">
              <span class="arrow">↑</span>
              <span>{heroCaption}</span>
            </figcaption>
          )}
        </figure>
      )}

      <div class="wrap-narrow center">
        {eyebrow && (
          <div class="eyebrow" style="margin-bottom: 18px">{eyebrow}</div>
        )}

        {greetingHtml && (
          <h1 class="home-greeting" set:html={greetingHtml} />
        )}

        {intro && (
          <p class="home-intro">{intro}</p>
        )}

        <div class="home-dogs">
          <DogAvatar dog="kujo" size={36} />
          <DogAvatar dog="kilo" size={36} />
        </div>
      </div>

      <div class="rule"><span class="rule-glyph" aria-hidden="true">· · ·</span></div>

      <div class="home-latest-head">
        <div class="eyebrow">{latelyLabel}</div>
        <a href="/journal" class="ink-link home-latest-all">All entries →</a>
      </div>

      <div>
        {recent.length === 0 ? (
          <p class="empty">Nothing here yet.</p>
        ) : (
          recent.map((post) => {
            const k = kindLabel[post.data.kind];
            const thumb = postThumb(post);
            return (
              <a href={`/journal/${post.slug}`} class="entry-row">
                <div class="thumb">
                  {thumb && <img src={thumb} alt="" loading="lazy" />}
                  {post.data.kind === 'video' && <div class="thumb-play" aria-hidden="true">▶</div>}
                </div>
                <div>
                  <div class="post-meta" style="margin-bottom: 8px">
                    <span class="kind-badge" data-kind={post.data.kind}>
                      <span class="kind-badge-icon">{k.icon}</span>
                      <span>{k.label}</span>
                    </span>
                    <span class="dot-sep"></span>
                    <span>{fmtDate(post.data.date)}</span>
                    <span class="dot-sep"></span>
                    <span>By {post.data.author}</span>
                  </div>
                  <h3>{post.data.title}</h3>
                  {post.data.excerpt && <p class="dek">{post.data.excerpt}</p>}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-foot-meta">
                      <div class="tag-list">
                        {post.data.tags.map((t: string) => (
                          <span class="tag">{t}</span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </a>
            );
          })
        )}
      </div>

      {nowBody && (
        <>
          <div class="rule"><span class="rule-glyph" aria-hidden="true">· · ·</span></div>
          <div class="now-card">
            <div class="eyebrow" style="margin-bottom: 10px">Now · {nowMonth}</div>
            <p class="now-card__body">{nowBody}</p>
          </div>
        </>
      )}
    </div>
  </div>
</Layout>

<style>
  .home-greeting { font-style: italic; line-height: 1.1; font-weight: 400; margin: 0; }
  .home-intro {
    margin-top: 32px;
    font-size: 19px;
    line-height: 1.7;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }
  .home-dogs { margin-top: 22px; display: flex; justify-content: center; gap: 10px; }
  .home-latest-head {
    margin-bottom: 24px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .home-latest-all { font-family: var(--sans); font-size: 13px; color: var(--muted); }
  .now-card__body {
    margin: 0;
    font-family: var(--serif-display);
    font-size: 20px;
    font-style: italic;
    line-height: 1.5;
  }
</style>
