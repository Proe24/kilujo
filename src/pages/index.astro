---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const journal = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="Home — Kilujo">
  <section class="intro">
    <h1>Hi, we're Gianna &amp; Stephen.</h1>
    <p>
      Mid-West meets East Asia — and two dogs, Kilo and Kujo, along for the ride.
      This is a small corner of the internet where we keep track of things we love:
      slow weekends, coffee shops we wander into, photos from our walks, and the
      games we play together.
    </p>
    <p>
      Pull up a chair and have a look around. There's more on the <a href="/about">about page</a>.
    </p>
  </section>

  <section>
    <div class="section-title">
      <h2>Recent journal entries</h2>
      <a href="/journal">All entries →</a>
    </div>
    {journal.length === 0 ? (
      <div class="empty">No journal entries yet.</div>
    ) : (
      <ul class="post-list">
        {journal.map((post) => (
          <li>
            <a href={`/journal/${post.slug}`}>{post.data.title}</a>
            <span class="post-meta">{formatDate(post.data.date)}{post.data.description ? ` — ${post.data.description}` : ''}</span>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>
