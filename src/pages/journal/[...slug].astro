---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('journal', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'journal'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title={`${post.data.title} — Journal`} description={post.data.description}>
  <a href="/journal" class="back-link">← Back to Journal</a>
  <article class="prose">
    <h1>{post.data.title}</h1>
    <span class="post-meta">
      {formatDate(post.data.date)}
      {post.data.author ? ` · By ${post.data.author}` : ''}
    </span>
    {post.data.tags && post.data.tags.length > 0 && (
      <div class="tag-row">
        {post.data.tags.map((t) => (
          <a class="tag" href={`/journal/tag/${t}`}>#{t}</a>
        ))}
      </div>
    )}
    <Content />
  </article>
</Layout>
