---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="Journal — A Quiet Corner">
  <section class="intro">
    <h1>Journal</h1>
    <p>Short notes and longer thoughts.</p>
  </section>

  {posts.length === 0 ? (
    <div class="empty">No entries yet. Add one in <code>src/content/journal/</code>.</div>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/journal/${post.slug}`}>{post.data.title}</a>
          <span class="post-meta">{formatDate(post.data.date)}{post.data.description ? ` — ${post.data.description}` : ''}</span>
        </li>
      ))}
    </ul>
  )}
</Layout>
