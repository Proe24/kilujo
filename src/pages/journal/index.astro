---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Pick a thumbnail: explicit cover, else first gallery image, else nothing.
// Lets video posts (which often skip cover) still show a poster in the list.
function postThumb(post: CollectionEntry<'journal'>): string | undefined {
  if (post.data.cover) return post.data.cover;
  const g = post.data.gallery?.[0];
  if (!g) return undefined;
  return typeof g === 'string' ? g : g.src;
}

const allTags = Array.from(new Set(posts.flatMap((p) => p.data.tags ?? []))).sort();
const allKinds = Array.from(new Set(posts.map((p) => p.data.kind)));

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const kindLabel: Record<string, { label: string; icon: string }> = {
  writing: { label: 'Writing', icon: '✎' },
  video:   { label: 'Video',   icon: '▶' },
  gaming:  { label: 'Gaming',  icon: '◆' },
};

// Order kind chips to match the kindLabel keys, then drop any not used.
const kindOrder = ['writing', 'video', 'gaming'];
const kindsInUse = kindOrder.filter((k) => allKinds.includes(k));
---
<Layout title="Journal — Kilujo">
  <div class="page">
    <div class="wrap">
      <header class="page-header">
        <div class="eyebrow" style="margin-bottom: 12px">The Journal</div>
        <h1><em>Notes, slowly written.</em></h1>
        <p class="lede">Writing, the occasional video, and notes on games we play together. All in one place.</p>
      </header>

      {(kindsInUse.length > 0 || allTags.length > 0) && (
        <div class="filters" data-filters>
          {kindsInUse.length > 0 && (
            <div class="tag-row tag-row--filter">
              <span class="tag-row__label">Type:</span>
              {kindsInUse.map((k) => (
                <button type="button" class="tag" data-filter="kind" data-value={k}>
                  <span style="font-size: 10px; line-height: 1">{kindLabel[k].icon}</span>
                  {kindLabel[k].label}
                </button>
              ))}
            </div>
          )}

          {allTags.length > 0 && (
            <div class="tag-row tag-row--filter">
              <span class="tag-row__label">Tag:</span>
              {allTags.map((t) => (
                <button type="button" class="tag" data-filter="tag" data-value={t}>{t}</button>
              ))}
            </div>
          )}

          <button type="button" class="filter-clear" data-filter-clear style="display: none">Clear filters</button>
        </div>
      )}

      {posts.length === 0 ? (
        <div class="empty">No entries yet. Add one in <code>src/content/journal/</code> (or via Pages CMS).</div>
      ) : (
        <div data-entry-list>
          {posts.map((post) => {
            const k = kindLabel[post.data.kind];
            const tagAttr = (post.data.tags ?? []).join('|');
            const thumb = postThumb(post);
            return (
              <a
                href={`/journal/${post.id}`}
                class="entry-row"
                data-entry
                data-kind={post.data.kind}
                data-tags={tagAttr}
              >
                <div class="thumb">
                  {thumb && <img src={thumb} alt="" loading="lazy" />}
                  {post.data.kind === 'video' && <div class="thumb-play" aria-hidden="true">▶</div>}
                </div>
                <div>
                  <div class="post-meta" style="margin-bottom: 8px">
                    <span class="kind-badge" data-kind={post.data.kind}>
                      <span class="kind-badge-icon">{k.icon}</span>
                      <span>{k.label}</span>
                    </span>
                    <span class="dot-sep"></span>
                    <span>{fmtDate(post.data.date)}</span>
                    <span class="dot-sep"></span>
                    <span>By {post.data.author}</span>
                  </div>
                  <h3>{post.data.title}</h3>
                  {post.data.excerpt && <p class="dek">{post.data.excerpt}</p>}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-foot-meta">
                      <div class="tag-list">
                        {post.data.tags.map((t: string) => (
                          <span class="tag">{t}</span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </a>
            );
          })}
          <p class="empty" data-empty-state style="display: none">No entries match these filters.</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .filters { margin-bottom: 1rem; }
  .filter-clear {
    appearance: none;
    background: none;
    border: 0;
    padding: 4px 0;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--muted);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .filter-clear:hover { color: var(--accent); }
</style>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-filters]');
    const list = document.querySelector('[data-entry-list]');
    if (!root || !list) return;

    const chips = root.querySelectorAll('button[data-filter]');
    const entries = list.querySelectorAll('[data-entry]');
    const empty = list.querySelector('[data-empty-state]');
    const clearBtn = root.querySelector('[data-filter-clear]');

    const state = { kind: '', tag: '' };

    function readUrl() {
      const p = new URLSearchParams(window.location.search);
      state.kind = p.get('kind') || '';
      state.tag = p.get('tag') || '';
    }

    function writeUrl() {
      const p = new URLSearchParams(window.location.search);
      state.kind ? p.set('kind', state.kind) : p.delete('kind');
      state.tag  ? p.set('tag',  state.tag)  : p.delete('tag');
      const qs = p.toString();
      const url = window.location.pathname + (qs ? '?' + qs : '');
      window.history.replaceState(null, '', url);
    }

    function render() {
      // Highlight active chips
      chips.forEach((c) => {
        const f = c.getAttribute('data-filter');
        const v = c.getAttribute('data-value');
        c.classList.toggle('active', state[f] === v);
      });

      // Filter entries. We use inline style.display rather than the [hidden]
      // attribute because .entry-row has `display: grid` in the stylesheet,
      // which wins over [hidden]'s default display: none.
      let shown = 0;
      entries.forEach((el) => {
        const kind = el.getAttribute('data-kind') || '';
        const tags = (el.getAttribute('data-tags') || '').split('|').filter(Boolean);
        const kindOk = !state.kind || state.kind === kind;
        const tagOk  = !state.tag  || tags.includes(state.tag);
        const match = kindOk && tagOk;
        el.style.display = match ? '' : 'none';
        if (match) shown++;
      });

      if (empty) empty.style.display = shown === 0 ? '' : 'none';
      if (clearBtn) clearBtn.style.display = (state.kind || state.tag) ? '' : 'none';
    }

    chips.forEach((c) => {
      c.addEventListener('click', () => {
        const f = c.getAttribute('data-filter');
        const v = c.getAttribute('data-value');
        state[f] = state[f] === v ? '' : v;
        writeUrl();
        render();
      });
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        state.kind = '';
        state.tag = '';
        writeUrl();
        render();
      });
    }

    // React to back/forward navigation between filter states
    window.addEventListener('popstate', () => {
      readUrl();
      render();
    });

    readUrl();
    render();
  })();
</script>
