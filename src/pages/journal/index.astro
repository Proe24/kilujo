---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = Array.from(new Set(posts.flatMap((p) => p.data.tags ?? []))).sort();

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const kindLabel: Record<string, { label: string; icon: string }> = {
  writing: { label: 'Writing', icon: '✎' },
  video:   { label: 'Video',   icon: '▶' },
  gaming:  { label: 'Gaming',  icon: '◆' },
};
---
<Layout title="Journal — Kilujo">
  <div class="page">
    <div class="wrap">
      <header class="page-header">
        <div class="eyebrow" style="margin-bottom: 12px">The Journal</div>
        <h1><em>Notes, slowly written.</em></h1>
        <p class="lede">Writing, the occasional video, and notes on games we play together. All in one place.</p>
      </header>

      {allTags.length > 0 && (
        <div class="tag-row tag-row--filter">
          <span class="tag-row__label">Browse by tag:</span>
          {allTags.map((t) => (
            <a class="tag" href={`/journal/tag/${t}`}>{t}</a>
          ))}
        </div>
      )}

      {posts.length === 0 ? (
        <div class="empty">No entries yet. Add one in <code>src/content/journal/</code> (or via Pages CMS).</div>
      ) : (
        <div>
          {posts.map((post) => {
            const k = kindLabel[post.data.kind];
            return (
              <a href={`/journal/${post.slug}`} class="entry-row">
                <div class="thumb">
                  {post.data.cover && <img src={post.data.cover} alt="" loading="lazy" />}
                  {post.data.kind === 'video' && <div class="thumb-play" aria-hidden="true">▶</div>}
                </div>
                <div>
                  <div class="post-meta" style="margin-bottom: 8px">
                    <span class="kind-badge" data-kind={post.data.kind}>
                      <span class="kind-badge-icon">{k.icon}</span>
                      <span>{k.label}</span>
                    </span>
                    <span class="dot-sep"></span>
                    <span>{fmtDate(post.data.date)}</span>
                    <span class="dot-sep"></span>
                    <span>By {post.data.author}</span>
                  </div>
                  <h3>{post.data.title}</h3>
                  {post.data.excerpt && <p class="dek">{post.data.excerpt}</p>}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-foot-meta">
                      <div class="tag-list">
                        {post.data.tags.map((t: string) => (
                          <span class="tag">{t}</span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </div>
</Layout>
