---
import Layout from '../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing src/content/pages/about.md');
const { Content } = await render(entry);
const { title, hero, heroAlt } = entry.data;
---
<Layout title={`${title} — Kilujo`} description="Kilo, Kujo, Gianna & Stephen — our story.">
  <div class="page">
    <div class="wrap">
      <article class="prose about">
        {hero && (
          <figure class="cover about__cover">
            <img src={hero} alt={heroAlt ?? ''} />
          </figure>
        )}
        <p class="about__eyebrow">About</p>
        <h1 class="about__title">{title}</h1>
        <div class="about__body">
          <Content />
        </div>
      </article>
    </div>
  </div>
</Layout>

<style>
  .about__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0 0 1rem;
  }
  .about__title {
    font-size: 2.6rem;
    letter-spacing: 0.05em;
    margin: 0 0 2rem;
  }
  .about__cover {
    max-height: 520px;
    margin-bottom: 2.5rem;
  }
  .about__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .about__body p:first-of-type {
    font-size: 1.15rem;
    color: var(--text);
  }
</style>
