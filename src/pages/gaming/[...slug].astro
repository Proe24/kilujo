---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('gaming', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'gaming'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title={`${post.data.title} — Gaming`} description={post.data.description}>
  <a href="/gaming" class="back-link">← Back to Gaming</a>
  <article class="prose">
    <h1>{post.data.title}</h1>
    <span class="post-meta">
      {formatDate(post.data.date)}
      {post.data.game ? ` — ${post.data.game}` : ''}
      {post.data.rating ? ` — ${post.data.rating}` : ''}
    </span>
    <Content />
  </article>
</Layout>
