---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('gaming', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="Gaming — Kilujo">
  <section class="intro">
    <h1>Gaming</h1>
    <p>What we're playing, and the occasional review.</p>
  </section>

  {posts.length === 0 ? (
    <div class="empty">No posts yet. Add one in <code>src/content/gaming/</code>.</div>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/gaming/${post.slug}`}>{post.data.title}</a>
          <span class="post-meta">
            {formatDate(post.data.date)}
            {post.data.game ? ` — ${post.data.game}` : ''}
            {post.data.rating ? ` — ${post.data.rating}` : ''}
          </span>
        </li>
      ))}
    </ul>
  )}
</Layout>
