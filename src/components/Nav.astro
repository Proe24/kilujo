---
const { pathname } = Astro.url;
// 5-item nav from the design. Projects temporarily points at /guides until
// a real Projects page is built.
const links = [
  { href: '/',         label: 'Home' },
  { href: '/journal',  label: 'Journal' },
  { href: '/photos',   label: 'Photos' },
  { href: '/projects', label: 'Projects' },
  { href: '/about',    label: 'About' },
];
function isActive(href: string) {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname === href || pathname.startsWith(href + '/');
}
---
<nav class="nav" role="navigation" aria-label="Primary">
  <a href="/" class="nav-marks" aria-label="kilujo, home">
    <span class="nav-mark"><span>kilujo</span><span class="dot">.</span></span>
  </a>
  <div class="nav-links">
    {links.map(({ href, label }) => (
      <a href={href} aria-current={isActive(href) ? 'page' : undefined}>{label}</a>
    ))}
  </div>
</nav>
