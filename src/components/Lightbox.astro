---
/*
 * Site-wide image lightbox. Mounted once in <Layout>; activates any element
 * marked with [data-lightbox]. Groups are formed via [data-lightbox-group="..."],
 * so prev/next cycle through the images that share a group on the page.
 *
 * Attributes on each trigger:
 *   data-lightbox            (presence — required)
 *   data-lightbox-group="x"  (string — required; same value for siblings)
 *   data-src="..."           (full-size image URL)
 *   data-alt="..."           (optional; falls back to inner <img>'s alt)
 *
 * Features: prev/next (buttons + ←/→), close (X + Esc + backdrop click),
 * zoom (wheel, +/-, double-click), pan when zoomed (mouse drag + touch drag),
 * pinch-to-zoom on touch, counter "n / total".
 */
---
<div
  id="lightbox"
  class="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
  aria-hidden="true"
  hidden
>
  <button class="lightbox__close" type="button" aria-label="Close (Esc)">
    <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
      <path d="M6 6l12 12M18 6l-12 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" fill="none"/>
    </svg>
  </button>

  <button class="lightbox__nav lightbox__nav--prev" type="button" aria-label="Previous (←)">
    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
      <path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  </button>
  <button class="lightbox__nav lightbox__nav--next" type="button" aria-label="Next (→)">
    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
      <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  </button>

  <div class="lightbox__stage">
    <img class="lightbox__image" alt="" draggable="false" />
  </div>

  <div class="lightbox__hud">
    <div class="lightbox__counter" aria-live="polite"></div>
    <div class="lightbox__zoom">
      <button class="lightbox__zoom-btn" type="button" data-zoom="-1" aria-label="Zoom out">−</button>
      <button class="lightbox__zoom-btn" type="button" data-zoom="reset" aria-label="Reset zoom">100%</button>
      <button class="lightbox__zoom-btn" type="button" data-zoom="+1" aria-label="Zoom in">+</button>
    </div>
  </div>
</div>

<style is:global>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(20, 16, 12, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .lightbox[hidden] { display: none; }
  .lightbox.is-open { opacity: 1; }

  .lightbox__stage {
    position: absolute;
    inset: 0;
    overflow: hidden;
    cursor: grab;
    touch-action: none;
  }
  .lightbox__stage.is-zoomed { cursor: grab; }
  .lightbox__stage.is-panning { cursor: grabbing; }

  .lightbox__image {
    position: absolute;
    left: 50%;
    top: 50%;
    max-width: 92vw;
    max-height: 86vh;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    transform-origin: center center;
    transition: transform 0.18s ease;
    user-select: none;
    -webkit-user-drag: none;
    will-change: transform;
    box-shadow: 0 18px 60px -20px rgba(0, 0, 0, 0.55);
    border-radius: 4px;
    background: #1c1814;
  }
  .lightbox__stage.is-panning .lightbox__image,
  .lightbox__stage.is-pinching .lightbox__image { transition: none; }

  .lightbox__close,
  .lightbox__nav,
  .lightbox__zoom-btn {
    appearance: none;
    background: rgba(28, 24, 20, 0.55);
    color: #f4ece0;
    border: 1px solid rgba(244, 236, 224, 0.12);
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .lightbox__close:hover,
  .lightbox__nav:hover,
  .lightbox__zoom-btn:hover {
    background: rgba(192, 138, 111, 0.85);
    border-color: rgba(192, 138, 111, 0.85);
    color: #fff;
  }
  .lightbox__close:focus-visible,
  .lightbox__nav:focus-visible,
  .lightbox__zoom-btn:focus-visible {
    outline: 2px solid #c08a6f;
    outline-offset: 2px;
  }

  .lightbox__close {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 40px; height: 40px;
    display: grid;
    place-items: center;
    z-index: 3;
  }

  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px; height: 44px;
    display: grid;
    place-items: center;
    z-index: 3;
  }
  .lightbox__nav--prev { left: 18px; }
  .lightbox__nav--next { right: 18px; }
  .lightbox__nav[hidden] { display: none; }

  .lightbox__hud {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--sans, ui-sans-serif, system-ui, sans-serif);
    font-size: 12px;
    color: rgba(244, 236, 224, 0.78);
    letter-spacing: 0.04em;
  }
  .lightbox__counter {
    background: rgba(28, 24, 20, 0.55);
    border: 1px solid rgba(244, 236, 224, 0.12);
    border-radius: 999px;
    padding: 6px 12px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    min-width: 56px;
    text-align: center;
  }
  .lightbox__counter:empty { display: none; }
  .lightbox__zoom { display: flex; gap: 6px; }
  .lightbox__zoom-btn {
    padding: 6px 10px;
    font-family: var(--sans, ui-sans-serif, system-ui, sans-serif);
    font-size: 12px;
    letter-spacing: 0.04em;
    min-width: 36px;
  }

  body.lightbox-open { overflow: hidden; }

  @media (max-width: 600px) {
    .lightbox__nav--prev { left: 8px; }
    .lightbox__nav--next { right: 8px; }
    .lightbox__close { top: 10px; right: 10px; }
    .lightbox__hud { bottom: 10px; }
  }
</style>

<script>
  // Self-contained lightbox controller.
  (() => {
    const root = document.getElementById('lightbox');
    if (!root) return;
    const stage = root.querySelector('.lightbox__stage') as HTMLElement;
    const img = root.querySelector('.lightbox__image') as HTMLImageElement;
    const btnClose = root.querySelector('.lightbox__close') as HTMLButtonElement;
    const btnPrev = root.querySelector('.lightbox__nav--prev') as HTMLButtonElement;
    const btnNext = root.querySelector('.lightbox__nav--next') as HTMLButtonElement;
    const counter = root.querySelector('.lightbox__counter') as HTMLElement;
    const zoomBtns = root.querySelectorAll<HTMLButtonElement>('.lightbox__zoom-btn');

    type Item = { src: string; alt: string };
    let group: Item[] = [];
    let index = 0;

    // Transform state
    let scale = 1;
    let tx = 0;
    let ty = 0;
    const MIN_SCALE = 1;
    const MAX_SCALE = 6;

    function applyTransform() {
      img.style.transform = `translate(calc(-50% + ${tx}px), calc(-50% + ${ty}px)) scale(${scale})`;
      stage.classList.toggle('is-zoomed', scale > 1.001);
      updateZoomLabel();
    }

    function updateZoomLabel() {
      const label = root.querySelector('.lightbox__zoom-btn[data-zoom="reset"]') as HTMLButtonElement | null;
      if (label) label.textContent = `${Math.round(scale * 100)}%`;
    }

    function resetTransform() {
      scale = 1;
      tx = 0;
      ty = 0;
      applyTransform();
    }

    function clampPan() {
      // Loose clamp: keep image roughly within the stage when zoomed.
      const rect = img.getBoundingClientRect();
      const stageRect = stage.getBoundingClientRect();
      const maxX = Math.max(0, (rect.width - stageRect.width) / 2 + 80);
      const maxY = Math.max(0, (rect.height - stageRect.height) / 2 + 80);
      tx = Math.min(maxX, Math.max(-maxX, tx));
      ty = Math.min(maxY, Math.max(-maxY, ty));
    }

    function setIndex(i: number) {
      if (group.length === 0) return;
      index = ((i % group.length) + group.length) % group.length;
      const item = group[index];
      img.src = item.src;
      img.alt = item.alt;
      resetTransform();
      counter.textContent = group.length > 1 ? `${index + 1} / ${group.length}` : '';
      const showNav = group.length > 1;
      btnPrev.hidden = !showNav;
      btnNext.hidden = !showNav;
    }

    function open(items: Item[], startIndex: number) {
      group = items;
      root.hidden = false;
      document.body.classList.add('lightbox-open');
      requestAnimationFrame(() => root.classList.add('is-open'));
      setIndex(startIndex);
    }

    function close() {
      root.classList.remove('is-open');
      document.body.classList.remove('lightbox-open');
      setTimeout(() => {
        root.hidden = true;
        img.src = '';
      }, 220);
    }

    function zoomBy(delta: number, originX?: number, originY?: number) {
      const prevScale = scale;
      const next = Math.min(MAX_SCALE, Math.max(MIN_SCALE, prevScale + delta));
      if (next === prevScale) return;
      if (originX != null && originY != null) {
        // Zoom toward the cursor position.
        const stageRect = stage.getBoundingClientRect();
        const cx = originX - (stageRect.left + stageRect.width / 2);
        const cy = originY - (stageRect.top + stageRect.height / 2);
        const ratio = next / prevScale;
        tx = ratio * tx - (ratio - 1) * cx;
        ty = ratio * ty - (ratio - 1) * cy;
      }
      scale = next;
      if (scale === 1) { tx = 0; ty = 0; } else { clampPan(); }
      applyTransform();
    }

    // --- Wire up triggers (event delegation so dynamically-added items work too).
    document.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement | null)?.closest<HTMLElement>('[data-lightbox]');
      if (!target) return;
      e.preventDefault();
      const groupName = target.getAttribute('data-lightbox-group') ?? '';
      const all = Array.from(
        document.querySelectorAll<HTMLElement>(`[data-lightbox][data-lightbox-group="${CSS.escape(groupName)}"]`)
      );
      const items: Item[] = all.map((el) => {
        const innerImg = el.querySelector('img');
        return {
          src: el.getAttribute('data-src') || (el as HTMLAnchorElement).href || innerImg?.src || '',
          alt: el.getAttribute('data-alt') || innerImg?.alt || '',
        };
      });
      const start = all.indexOf(target);
      open(items, Math.max(0, start));
    });

    // --- Controls
    btnClose.addEventListener('click', close);
    btnPrev.addEventListener('click', () => setIndex(index - 1));
    btnNext.addEventListener('click', () => setIndex(index + 1));
    zoomBtns.forEach((b) => {
      b.addEventListener('click', () => {
        const v = b.getAttribute('data-zoom');
        if (v === 'reset') resetTransform();
        else if (v === '+1') zoomBy(0.5);
        else if (v === '-1') zoomBy(-0.5);
      });
    });

    // Backdrop click (but not when clicking the image or any control).
    stage.addEventListener('click', (e) => {
      if (e.target === stage) close();
    });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (root.hidden) return;
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); setIndex(index - 1); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); setIndex(index + 1); }
      else if (e.key === '+' || e.key === '=') { e.preventDefault(); zoomBy(0.5); }
      else if (e.key === '-' || e.key === '_') { e.preventDefault(); zoomBy(-0.5); }
      else if (e.key === '0') { e.preventDefault(); resetTransform(); }
    });

    // Wheel zoom (only over the stage, when open).
    stage.addEventListener('wheel', (e) => {
      if (root.hidden) return;
      e.preventDefault();
      const delta = e.deltaY < 0 ? 0.2 : -0.2;
      zoomBy(delta, e.clientX, e.clientY);
    }, { passive: false });

    // Double-click toggles zoom.
    img.addEventListener('dblclick', (e) => {
      if (scale > 1.001) resetTransform();
      else zoomBy(1.5, e.clientX, e.clientY);
    });

    // --- Pointer drag for panning (also serves as touch drag).
    let pointers = new Map<number, { x: number; y: number }>();
    let dragStart: { x: number; y: number; tx: number; ty: number } | null = null;
    let pinchStart: { dist: number; scale: number } | null = null;
    // Track horizontal travel for swipe-to-nav at scale 1.
    let swipeStartX = 0;
    let swipeAccumX = 0;

    function distance(a: { x: number; y: number }, b: { x: number; y: number }) {
      const dx = a.x - b.x, dy = a.y - b.y;
      return Math.hypot(dx, dy);
    }

    stage.addEventListener('pointerdown', (e) => {
      if (root.hidden) return;
      stage.setPointerCapture(e.pointerId);
      pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });

      if (pointers.size === 1) {
        dragStart = { x: e.clientX, y: e.clientY, tx, ty };
        swipeStartX = e.clientX;
        swipeAccumX = 0;
        stage.classList.add('is-panning');
      } else if (pointers.size === 2) {
        const pts = Array.from(pointers.values());
        pinchStart = { dist: distance(pts[0], pts[1]), scale };
        stage.classList.add('is-pinching');
        dragStart = null;
      }
    });

    stage.addEventListener('pointermove', (e) => {
      if (!pointers.has(e.pointerId)) return;
      pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });

      if (pointers.size === 2 && pinchStart) {
        const pts = Array.from(pointers.values());
        const d = distance(pts[0], pts[1]);
        const next = Math.min(MAX_SCALE, Math.max(MIN_SCALE, pinchStart.scale * (d / pinchStart.dist)));
        scale = next;
        if (scale === 1) { tx = 0; ty = 0; } else { clampPan(); }
        applyTransform();
      } else if (pointers.size === 1 && dragStart) {
        const dx = e.clientX - dragStart.x;
        const dy = e.clientY - dragStart.y;
        if (scale > 1.001) {
          tx = dragStart.tx + dx;
          ty = dragStart.ty + dy;
          clampPan();
          applyTransform();
        } else {
          swipeAccumX = dx;
        }
      }
    });

    function endPointer(e: PointerEvent) {
      if (!pointers.has(e.pointerId)) return;
      pointers.delete(e.pointerId);
      if (pointers.size < 2) pinchStart = null;
      if (pointers.size === 0) {
        stage.classList.remove('is-panning', 'is-pinching');
        // Swipe-to-nav when not zoomed.
        if (dragStart && scale <= 1.001 && Math.abs(swipeAccumX) > 60) {
          if (swipeAccumX < 0) setIndex(index + 1);
          else setIndex(index - 1);
        }
        dragStart = null;
      }
    }
    stage.addEventListener('pointerup', endPointer);
    stage.addEventListener('pointercancel', endPointer);
    stage.addEventListener('pointerleave', endPointer);
  })();
</script>
